<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/math_bg_light"
    tools:context=".presentation.splash.SplashActivity">

    <!-- Grid background layer -->
    <com.explorebyte.ar.presentation.splash.GridBackgroundView
        android:id="@+id/gridBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="32dp">

        <!-- Visual Assets Area -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="80dp">

            <!-- Triangle (Yellow) -->
            <ImageView
                android:id="@+id/ivTriangle"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_math_triangle"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="60dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Rounded Cube (Blue) -->
            <FrameLayout
                android:id="@+id/flCubeContainer"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_math_cube_rounded"
                android:elevation="4dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/ivCube"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_math_cube_white" />
            </FrameLayout>

            <!-- Circle (Pink) -->
            <ImageView
                android:id="@+id/ivCircle"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_math_circle"
                android:layout_marginStart="40dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- App branding section -->
        <LinearLayout
            android:id="@+id/brandingSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="60dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MathScholAR"
                android:textColor="@color/math_text_primary"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ayo Belajar Geometri!"
                android:textColor="@color/math_blue_main"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Dunia matematika seru dalam AR"
                android:textColor="@color/math_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Initialize button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnInitialize"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_math_button"
            android:drawableEnd="@drawable/ic_math_play"
            android:drawablePadding="12dp"
            android:paddingHorizontal="24dp"
            android:text="Mulai Belajar"
            android:textAllCaps="false"
            android:textColor="@color/math_button_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:elevation="8dp" />

        <!-- Progress Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <ProgressBar
                android:id="@+id/pbSplash"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="120dp"
                android:layout_height="4dp"
                android:progress="40"
                android:progressTint="@color/math_blue_main" />

            <TextView
                android:id="@+id/tvSystemStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Menyiapkan Ruang Belajar..."
                android:textColor="@color/math_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="24dp"
            android:text="BELAJAR JADI MUDAH DENGAN AR - 2026"
            android:textColor="#BDBDBD"
            android:textSize="10sp"
            android:letterSpacing="0.05" />

    </LinearLayout>

</FrameLayout>
